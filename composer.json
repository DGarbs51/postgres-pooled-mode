{
    "name": "dgarbs51/postgres-pooled-mode",
    "description": "Drop-in Laravel support for PostgreSQL transaction poolers with direct connections for schema operations.",
    "keywords": [
        "laravel",
        "postgres",
        "postgresql",
        "pgbouncer",
        "rds-proxy",
        "connection-pooling"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "DGarbs51"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "DGarbs51\\PostgresPooledMode\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DGarbs51\\PostgresPooledMode\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DGarbs51\\PostgresPooledMode\\PostgresPooledModeServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "format": "pint"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
